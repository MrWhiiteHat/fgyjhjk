# Production environment template
ENVIRONMENT=production
LOG_LEVEL=INFO
API_KEY=replace-with-production-fallback-key
OPS_API_KEYS_JSON={"prod-client":{"key":"replace-with-prod-public-key","role":"public"},"prod-admin":{"key":"replace-with-prod-admin-key","role":"admin"}}
PROMETHEUS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
MODEL_VALIDATION_REQUIRED=true
PROMOTION_REQUIRES_APPROVAL=true
BACKUP_ENCRYPTION_ENABLED=true
