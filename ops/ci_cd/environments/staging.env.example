# Staging environment template
ENVIRONMENT=staging
LOG_LEVEL=INFO
API_KEY=replace-with-staging-key
OPS_API_KEYS_JSON={"staging-client":{"key":"replace-with-staging-public-key","role":"public"},"staging-admin":{"key":"replace-with-staging-admin-key","role":"admin"}}
PROMETHEUS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
MODEL_VALIDATION_REQUIRED=true
PROMOTION_REQUIRES_APPROVAL=false
