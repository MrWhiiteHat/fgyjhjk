{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/billable_event.schema.json",
  "title": "BillableEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "tenant_id",
    "metric",
    "quantity",
    "occurred_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": ["string", "null"]
    },
    "metric": {
      "type": "string",
      "enum": [
        "image_inference",
        "video_inference",
        "explainability_usage",
        "storage_usage",
        "async_jobs"
      ]
    },
    "quantity": {
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
