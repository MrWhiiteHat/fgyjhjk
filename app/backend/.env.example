APP_NAME=RealFakeDetectionAPI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

MODEL_ARTIFACT_PATH=training/outputs/checkpoints/real_fake_baseline/best_model.pt
MODEL_TYPE=pytorch
DEVICE=auto
MODEL_PRELOAD_ON_STARTUP=true
DEFAULT_THRESHOLD=0.50
UNCERTAIN_MARGIN=0.08

MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=250
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.webp
ALLOWED_VIDEO_EXTENSIONS=.mp4,.avi,.mov,.mkv,.webm

TEMP_DIR=app/backend/tmp
OUTPUT_DIR=app/backend/outputs
TEMP_CLEANUP_ENABLED=true
TEMP_MAX_AGE_SECONDS=3600
PRESERVE_FAILED_UPLOADS=false

ENABLE_EXPLAINABILITY=true
ENABLE_REPORT_EXPORT=true
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

REQUEST_TIMEOUT_SEC=60
PREDICTION_CACHE_TTL=300
MAX_BATCH_SIZE=64
VIDEO_DEFAULT_FRAME_STRIDE=3
VIDEO_DEFAULT_MAX_FRAMES=60
VIDEO_MAX_FRAMES_PER_REQUEST=180
VIDEO_MAX_FRAME_STRIDE=16
VIDEO_INFERENCE_BATCH_SIZE=4
EXPLAIN_MAX_IMAGE_SIDE=1280

ENABLE_AUTH=false
API_KEY=your_api_key_here

ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=120

SAVE_UPLOADS=false
SAVE_ANNOTATED_OUTPUTS=false
SAVE_EXPLAINABILITY_PANELS=false
SAVE_REPORTS=true

FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000

METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
